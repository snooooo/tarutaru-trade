NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — used server-side only for admin operations (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=
# Backward-compatible alias if the deployment already uses this name
SUPABASE_SERVICE_KEY=
# Comma-separated Supabase user UUIDs that have admin access
ADMIN_USER_IDS=

# Resend email notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Public URL used in notification emails, e.g. https://tarutaru.example.com
TARUTARU_TRADE_APP_URL=
